[Unit]
Description=official-sources local artifact integrity check
Documentation=https://github.com/example/official-sources

[Service]
Type=oneshot
User=official-sources
Group=official-sources
WorkingDirectory=/opt/official-sources/app
EnvironmentFile=/opt/official-sources/.env
ExecStart=/opt/official-sources/app/.venv/bin/official-sources integrity-check --date today
ExecStart=/opt/official-sources/app/.venv/bin/official-sources status --date today
NoNewPrivileges=true
PrivateTmp=true
